<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Utsavya - Plan Any Event</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="css/landing_enhanced.css">
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar" id="navbar">
    <div class="logo">
        UTSAVYA <span class="logo-dot"></span>
    </div>
    <ul class="nav-links">
        <li>Home</li>
        <li>Events</li>
        <li>Vendors</li>
        <li>Memories</li>
        <li>Pricing</li>
    </ul>
    <div class="nav-buttons">
        <button class="login-btn">Login</button>
        <button class="signup-btn">Sign Up Free</button>
    </div>
</nav>


<!-- HERO -->
<section class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-ring"></div>
    <div class="bokeh">
        <span></span><span></span><span></span>
        <span></span><span></span><span></span>
    </div>

    <div class="hero-content">
        <div class="hero-tag">India's #1 Event Planning Platform</div>

        <h1>
            Karo Har Event,
            <span class="accent">Perfectly Planned</span>
        </h1>

        <p>Find trusted vendors, manage schedules, and organize your entire event — all in one place.</p>

        <div class="search-box">
            <div class="search-field">
                <input type="text" placeholder="What event are you planning?">
            </div>
            <div class="divider"></div>
            <div class="search-field">
                <input type="text" placeholder="City">
            </div>
            <div class="divider"></div>
            <div class="search-field">
                <input type="date">
            </div>
            <button class="search-btn">Find Vendors →</button>
        </div>

        <div class="metrics">
            <div class="metric-item">
                <h3>1,000+</h3>
                <p>Vendors</p>
            </div>
            <div class="metric-sep"></div>
            <div class="metric-item">
                <h3>50+</h3>
                <p>Cities</p>
            </div>
            <div class="metric-sep"></div>
            <div class="metric-item">
                <h3>25,000+</h3>
                <p>Events Planned</p>
            </div>
        </div>
    </div>
</section>


<!-- CATEGORIES -->
<section class="categories reveal">
    <span class="section-label">Browse by Type</span>
    <h2 class="section-title">Event Categories</h2>
    <p class="section-sub">From intimate gatherings to grand celebrations — we've got you covered</p>

    <div class="category-grid">
        <div class="category-card">
            <div class="card-img-wrap">
                <img src="/images/wedding.png" alt="Wedding">
            </div>
            <div class="card-body">
                <h3>Wedding</h3>
                <p class="vendor-count">2,500+ vendors</p>
                <button>Explore Vendors</button>
            </div>
        </div>
        <div class="category-card">
            <div class="card-img-wrap">
                <img src="/images/birthday.jpg" alt="Birthday">
            </div>
            <div class="card-body">
                <h3>Birthday</h3>
                <p class="vendor-count">1,800+ vendors</p>
                <button>Explore Vendors</button>
            </div>
        </div>
        <div class="category-card">
            <div class="card-img-wrap">
                <img src="/images/festival.jpg" alt="Festival">
            </div>
            <div class="card-body">
                <h3>Festival</h3>
                <p class="vendor-count">250+ vendors</p>
                <button>Explore Vendors</button>
            </div>
        </div>
        <div class="category-card">
            <div class="card-img-wrap">
                <img src="/images/corporate.jpeg" alt="Corporate">
            </div>
            <div class="card-body">
                <h3>Corporate</h3>
                <p class="vendor-count">900+ vendors</p>
                <button>Explore Vendors</button>
            </div>
        </div>
    </div>
</section>


<!-- HOW IT WORKS -->
<section class="how-it-works reveal">
    <span class="section-label">Simple Process</span>
    <h2 class="section-title">How Utsavya Works</h2>
    <p class="section-sub">Three easy steps to your perfect event</p>

    <div class="steps">
        <div class="step">
            <div class="step-number">1</div>
            <img src="/images/choose event.png" alt="">
            <h3>Choose Your Event</h3>
            <p>Select from weddings, birthdays, corporate events, or festivals</p>
        </div>
        <div class="step">
            <div class="step-number">2</div>
            <img src="/images/find vendors.png" alt="">
            <h3>Find Vendors</h3>
            <p>Compare decorators, caterers, photographers and more</p>
        </div>
        <div class="step">
            <div class="step-number">3</div>
            <img src="/images/plan and manage.png" alt="">
            <h3>Plan & Manage</h3>
            <p>Track tasks and manage your full event schedule in one dashboard</p>
        </div>
    </div>
</section>


<!-- VENDORS -->
<section class="vendors reveal">
    <span class="section-label">Top Rated</span>
    <h2 class="section-title">Featured Vendors</h2>
    <p class="section-sub">Trusted by thousands of happy clients across India</p>

    <div class="vendor-grid">
        <div class="vendor-card">
            <div class="vendor-img-wrap">
                <img src="/images/catering.jpg" alt="Royal Caterers">
                <span class="vendor-badge">⭐ 4.8</span>
            </div>
            <div class="vendor-body">
                <h3>Royal Caterers</h3>
                <p class="city">Delhi</p>
            </div>
        </div>
        <div class="vendor-card">
            <div class="vendor-img-wrap">
                <img src="/images/royal decorators.jpg" alt="Sharma Decorations">
                <span class="vendor-badge">⭐ 4.7</span>
            </div>
            <div class="vendor-body">
                <h3>Sharma Decorations</h3>
                <p class="city">Jaipur</p>
            </div>
        </div>
        <div class="vendor-card">
            <div class="vendor-img-wrap">
                <img src="/images/photography.jpg" alt="Moonlight Photography">
                <span class="vendor-badge">⭐ 4.9</span>
            </div>
            <div class="vendor-body">
                <h3>Moonlight Photography</h3>
                <p class="city">Mumbai</p>
            </div>
        </div>
        <div class="vendor-card">
            <div class="vendor-img-wrap">
                <img src="/images/my wedding.jpg" alt="Elite Wedding Planners">
                <span class="vendor-badge">⭐ 4.9</span>
            </div>
            <div class="vendor-body">
                <h3>Elite Wedding Planners</h3>
                <p class="city">Bangalore</p>
            </div>
        </div>
    </div>
</section>


<!-- CTA -->
<section class="cta reveal">
    <h2>Ready to Plan Your Event?</h2>
    <p>Start organizing in minutes — with India's most trusted vendors by your side</p>
    <button>Get Started for Free</button>
</section>


<!-- FOOTER -->
<footer class="footer">
    <p>© 2026 Utsavya · All Rights Reserved · Made with ❤️ in India</p>
</footer>


<script>
    // Scroll reveal
    function reveal() {
        document.querySelectorAll('.reveal').forEach(el => {
            if (el.getBoundingClientRect().top < window.innerHeight - 100) {
                el.classList.add('active');
            }
        });
    }
    window.addEventListener('scroll', reveal);
    reveal();

    // Parallax hero
    const hero = document.querySelector('.hero');
    window.addEventListener('scroll', () => {
        requestAnimationFrame(() => {
            hero.style.backgroundPosition = `center ${window.scrollY * 0.35}px`;
        });
    });

    // Navbar shadow on scroll
    window.addEventListener('scroll', () => {
        document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 10);
    });
</script>

</body>
</html>
